                '.highlight-blue   { background: #dbeafe !important; }' +
                '.highlight-pink   { background: #fce7f3 !important; }' +
                '.highlight-orange { background: #ffedd5 !important; }' +
                '[data-theme="dark"] { background: #0f172a; color: #e2e8f0; }' +
                '[data-theme="sepia"] body, [data-theme="sepia"] .main-content { background: #fdf3e3; color: #3d2b1f; }';
            document.head.appendChild(style);
        })();

        // ============================================================
        // INITIALIZE
        // ============================================================

        // ── AUTH GATE FUNCTIONS ──────────────────────────────

        var _ownerHash = 'U2NyaXB0dXJlU3R1ZGlvMQ=='; // base64 of ScriptureStudio1


        function togglePwVisibility() {
            var inp  = document.getElementById('ownerPwInput');
            var icon = document.getElementById('eyeIcon');
            if (!inp) return;
            var showing = inp.type === 'text';
            inp.type = showing ? 'password' : 'text';
            // Swap between eye and eye-off SVG paths
            if (showing) {
                icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
            } else {
                icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>' +
                    '<path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>' +
                    '<line x1="1" y1="1" x2="23" y2="23"/>';
            }
            inp.focus();
        }
        function openOwnerPwModal() {
            var modal = document.getElementById('owner-pw-modal');
            var input = document.getElementById('ownerPwInput');
            if (modal) modal.classList.add('open');
            if (input) { input.value = ''; input.focus(); }
            document.getElementById('pwError').textContent = '';
        }

        function closeOwnerPwModal() {
            var modal = document.getElementById('owner-pw-modal');
            if (modal) modal.classList.remove('open');
        }

        function checkOwnerPw() {
            var input = document.getElementById('ownerPwInput');
            var errEl = document.getElementById('pwError');
            var val   = input ? input.value.trim() : '';
            var encoded = btoa(val);
            if (encoded === _ownerHash) {
                closeOwnerPwModal();
                bypassAuth();
            } else {
                errEl.textContent = 'Incorrect password. Try again.';
                input.classList.add('shake');
                input.value = '';
                setTimeout(function() { input.classList.remove('shake'); input.focus(); }, 450);
            }
        }

        function bypassAuth() {
            var gate = document.getElementById('auth-gate');
            var app  = document.getElementById('main-app');
            if (gate) gate.classList.add('hidden');
            if (app)  app.style.display = '';
        }

        function showApp(user) {
            var gate = document.getElementById('auth-gate');
            var app  = document.getElementById('main-app');
            if (gate) gate.classList.add('hidden');
            if (app)  app.style.display = '';
            if (user) {
                var nameEl    = document.getElementById('userName');
                var initEl    = document.getElementById('userInitials');
                var emailEl   = document.getElementById('settingsEmail');
                var planEl    = document.getElementById('settingsPlan');
                var greetEl   = document.getElementById('auth-greeting');
                var fullName  = user.FullName || user.Email || 'Pastor';
                var firstName = fullName.split(' ')[0];
                if (nameEl)   nameEl.textContent  = fullName;
                if (initEl)   initEl.textContent  = fullName.charAt(0).toUpperCase();
                if (emailEl)  emailEl.value = user.Email || '';
                if (greetEl)  greetEl.textContent = 'Welcome back, ' + firstName + '!';
                if (planEl && user.Account && user.Account.CurrentSubscription)
                    planEl.value = user.Account.CurrentSubscription.Plan.Name;
            }
        }

        function showAuthGate() {
            var gate = document.getElementById('auth-gate');
            var app  = document.getElementById('main-app');
            if (gate) gate.classList.remove('hidden');
            if (app)  app.style.display = 'none';
        }

        function openOutsetaLogin() {
            if (window.Outseta && window.Outseta.auth) {
                try { window.Outseta.auth.open({ widgetMode: 'login' }); return; } catch(e) {}
            }
            window.open('https://scripturestudio.outseta.com/auth?widgetMode=login#o-anonymous', '_blank');
        }

        function openOutsetaSignup() {
            if (window.Outseta && window.Outseta.auth) {
                try { window.Outseta.auth.open({ widgetMode: 'register' }); return; } catch(e) {}
            }
            window.open('https://scripturestudio.outseta.com/auth?widgetMode=register#o-anonymous', '_blank');
        }

        function tryOutsetaLogin(e) {
            if (window.Outseta && window.Outseta.auth) {
                try { e.preventDefault(); window.Outseta.auth.open({ widgetMode: 'login' }); } catch(ex) {}
            }
            // else let the href handle it
        }

        function tryOutsetaSignup(e) {
            if (window.Outseta && window.Outseta.auth) {
                try { e.preventDefault(); window.Outseta.auth.open({ widgetMode: 'register' }); } catch(ex) {}
            }
        }

        function initAuthGate() {
            if (!window.Outseta) {
                setTimeout(initAuthGate, 150);
                return;
            }
            var user = null;
            try { user = window.Outseta.getUser ? window.Outseta.getUser() : null; } catch(e) {}
            if (user && user.Email) {
                showApp(user);
            } else {
                showAuthGate();
            }
            window.addEventListener('outseta.onAccessTokenAdded', function() {
                var u = null;
                try { u = window.Outseta.getUser ? window.Outseta.getUser() : null; } catch(e) {}
                showApp(u);
            });
            window.addEventListener('outseta.onAccessTokenRemoved', function() {
                showAuthGate();
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Nav item click handlers
            document.querySelectorAll('.nav-item').forEach(function(item) {
                item.addEventListener('click', function() { navigateTo(item.dataset.page); });
            });

            // Modal action button
            const modalBtn = document.getElementById('modalAction');
            if (modalBtn) modalBtn.addEventListener('click', function() { if (modalActionFn) modalActionFn(); });

            // Set sermon date
            const sermonDate = document.getElementById('sermonDate');
            if (sermonDate) sermonDate.value = new Date().toISOString().split('T')[0];

            // Global search
            const search = document.getElementById('globalSearch');
            if (search) {
                search.addEventListener('keyup', function(e) {
                    if (e.key === 'Enter') {
                        const q = search.value.trim();
                        if (q) { navigateTo('bible-reader'); showToast('Searching: ' + q); }
                    }
                });
            }

            // Populate Bible selects
            populateBookSelect();
            updateChapterSelect();

            // Apply saved settings
            applySettings();

            // Seed default data
            seedDefaultIllustrations();

            // Load dashboard data
            loadDashboard();

            // Load Bible (Genesis 1 by default)
            loadChapter();

            // Auth gate init
            initAuthGate();

            console.log('Scripture Studio initialized successfully!');
        });
    </script>
</body>
