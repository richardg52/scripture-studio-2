        function loadPrayers(filter) {
            filter = filter || 'all';
            let prayers = getPrayers();
            if (filter === 'answered') prayers = prayers.filter(p => p.answered);
            if (filter === 'ongoing') prayers = prayers.filter(p => !p.answered);
            const list = document.getElementById('prayerList');
            if (!list) return;
