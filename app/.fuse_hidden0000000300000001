        function populateCommentaryBooks() {
            var sel = document.getElementById('commentaryBookSel');
            if (!sel || sel.options.length > 0) return;
            bibleBooks.forEach(function(b) {
                var opt = document.createElement('option');
                opt.value = b.name;
                opt.textContent = b.name;
                if (b.name === AppState.currentBook) opt.selected = true;
                sel.appendChild(opt);
            });
            updateCommentaryChapters();
        }

        function updateCommentaryChapters() {
            var bookSel = document.getElementById('commentaryBookSel');
            var chapSel = document.getElementById('commentaryChapSel');
            if (!bookSel || !chapSel) return;
            var bookName = bookSel.value;
            var bookData = bibleBooks.find(function(b){ return b.name === bookName; });
            var chapters = bookData ? bookData.chapters : 50;
            chapSel.innerHTML = '';
            for (var i = 1; i <= chapters; i++) {
                var opt = document.createElement('option');
                opt.value = i;
                opt.textContent = i;
                if (i === AppState.currentChapter) opt.selected = true;
                chapSel.appendChild(opt);
            }
        }

        var cTransMap = {KJV:'kjv',NKJV:'kjv',ASV:'kjv',WEB:'web',ESV:'web',NIV:'web',NASB:'web',NLT:'web'};

        async function loadCommentaryBibleText(ref) {
            var elA = document.getElementById('cBibleA');
            var elB = document.getElementById('cBibleB');
            var selA = document.getElementById('cTransA');
            var selB = document.getElementById('cTransB');
            if (!elA || !elB || !selA || !selB || !ref) return;
            var transA = selA.value || 'KJV';
            var transB = selB.value || 'WEB';
            var apiA = cTransMap[transA] || 'kjv';
            var apiB = cTransMap[transB] || 'web';
            var apiRef = encodeURIComponent(ref);
            elA.innerHTML = '<span style="color:#94a3b8;font-style:italic">Loading ' + transA + '...</span>';
            elB.innerHTML = '<span style="color:#94a3b8;font-style:italic">Loading ' + transB + '...</span>';
            function renderVerses(data, label) {
                if (!data || !data.verses || data.verses.length === 0) {
                    return '<span style="color:#94a3b8;font-style:italic">Text not available for this translation.</span>';
                }
                var html = '<div style="font-size:0.75rem;font-weight:700;color:#1e40af;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em">' + label + ' — ' + (data.reference || ref) + '</div>';
                data.verses.forEach(function(v) {
                    html += '<sup style="color:#1e40af;font-weight:700;font-size:0.7rem;margin-right:3px">' + v.verse + '</sup>' + v.text + ' ';
                });
                return html;
            }
            try {
                var results = await Promise.all([
                    fetch('https://bible-api.com/' + apiRef + '?translation=' + apiA).then(function(r){ return r.json(); }).catch(function(){ return null; }),
                    fetch('https://bible-api.com/' + apiRef + '?translation=' + apiB).then(function(r){ return r.json(); }).catch(function(){ return null; })
                ]);
                elA.innerHTML = renderVerses(results[0], transA);
                elB.innerHTML = renderVerses(results[1], transB);
            } catch(e) {
                elA.innerHTML = '<span style="color:#ef4444;font-size:0.85rem">Could not load. Check your connection.</span>';
                elB.innerHTML = '<span style="color:#ef4444;font-size:0.85rem">Could not load. Check your connection.</span>';
            }
        }

        function lookUpCommentary() {
            var bookSel  = document.getElementById('commentaryBookSel');
            var chapSel  = document.getElementById('commentaryChapSel');
            var verseInp = document.getElementById('commentaryVerseRange');
            if (!bookSel || !chapSel) return;
            var ref = bookSel.value + ' ' + chapSel.value;
            if (verseInp && verseInp.value.trim()) ref += ':' + verseInp.value.trim();
            var activeTab = document.querySelector('.commentary-tab.active');
            var type = 'bishops';
            if (activeTab) {
                var txt = activeTab.textContent.toLowerCase();
                if (txt.indexOf('matthew') !== -1) type = 'matthew';
                else if (txt.indexOf('jamieson') !== -1) type = 'jamieson';
            }
            loadCommentaryBibleText(ref);
            loadCommentary(type, activeTab, ref);
        }

        function useCurrentPassage() {
            var activeTab = document.querySelector('.commentary-tab.active');
            var type = 'bishops';
            if (activeTab) {
                var txt = activeTab.textContent.toLowerCase();
                if (txt.indexOf('matthew') !== -1) type = 'matthew';
                else if (txt.indexOf('jamieson') !== -1) type = 'jamieson';
            }
            var bookSel = document.getElementById('commentaryBookSel');
            var chapSel = document.getElementById('commentaryChapSel');
            if (bookSel) bookSel.value = AppState.currentBook;
            updateCommentaryChapters();
