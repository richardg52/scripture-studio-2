        function lookupPronunciation() {
            var q = document.getElementById('pronSearch') ? document.getElementById('pronSearch').value.trim() : '';
            if (!q) return;
            pronunciationShow(q);
        }
        function quickPronounce(word) {
            var el = document.getElementById('pronSearch');
            if (el) el.value = word;
            pronunciationShow(word);
        }
        function pronunciationShow(word) {
            var el = document.getElementById('pronunciationResult');
            if (!el) return;
            var key  = word.toLowerCase();
            var data = pronDatabase[key];
            if (!data) {
                el.innerHTML = '<div style="background:#f8fafc;border-radius:10px;padding:20px;text-align:center">' +
                    '<p style="color:#64748b;margin-bottom:8px">No entry found for "' + word + '"</p>' +
                    '<p style="font-size:0.85rem;color:#94a3b8">Try one of the common challenges above, or use the Hebrew & Greek Lexicon for original language words.</p></div>';
                return;
            }
            el.innerHTML = '<div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden">' +
                '<div style="background:linear-gradient(135deg,#4f46e5,#7c3aed);padding:20px;color:#fff">' +
                '<h3 style="font-size:1.4rem;margin-bottom:4px;text-transform:capitalize">' + word + '</h3>' +
                '<p style="opacity:0.85;font-size:1rem;font-style:italic">' + data.pron + '</p>' +
                '<p style="opacity:0.7;font-size:0.85rem;margin-top:4px;letter-spacing:2px">' + data.syllables + '</p>' +
                '<button onclick="speakBiblicalWord(\'' + word + '\', \'' + data.syllables + '\')" style="margin-top:10px;background:rgba(255,255,255,0.22);border:1px solid rgba(255,255,255,0.4);border-radius:20px;padding:6px 16px;color:white;font-size:0.82rem;cursor:pointer;display:inline-flex;align-items:center;gap:6px">&#128264; Hear it Again</button>' +
                '</div>' +
                '<div style="padding:18px">' +
                '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">' +
                '<div style="background:#f8fafc;border-radius:8px;padding:12px"><p style="font-size:0.75rem;text-transform:uppercase;color:#94a3b8;margin-bottom:4px">Language Origin</p><p style="font-weight:600;color:#1e293b">' + data.origin + '</p></div>' +
                '<div style="background:#f8fafc;border-radius:8px;padding:12px"><p style="font-size:0.75rem;text-transform:uppercase;color:#94a3b8;margin-bottom:4px">Meaning</p><p style="font-weight:600;color:#1e293b">' + data.meaning + '</p></div></div>' +
                '<div style="background:#f0f9ff;border-radius:8px;padding:14px">' +
                '<p style="font-size:0.75rem;text-transform:uppercase;color:#1e40af;margin-bottom:6px">Biblical Context</p>' +
                '<p style="color:#334155;font-size:0.9rem;line-height:1.7">' + data.context + '</p></div>' +
                '<div style="background:#f0fdf4;border-radius:8px;padding:12px;margin-top:12px">' +
                '<p style="font-size:0.75rem;text-transform:uppercase;color:#166534;margin-bottom:4px">Pulpit Tip</p>' +
                '<p style="color:#374151;font-size:0.9rem">Say it aloud 3 times before Sunday. Break it into syllables: <strong>' + data.syllables + '</strong></p></div>' +
                '</div></div>';
            // Speak the word aloud using Web Speech API
            setTimeout(function() {
                speakBiblicalWord(word, data.syllables);
            }, 400);
            showToast('Pronunciation: ' + data.pron + ' — Listen now!');
        }
        function speakBiblicalWord(word, syllables) {
            if (!('speechSynthesis' in window)) {
                showToast('Audio not supported in this browser');
                return;
            }
            window.speechSynthesis.cancel();
            // Speak the word itself slowly
            var utt = new SpeechSynthesisUtterance(word);
            utt.rate  = 0.72;
            utt.pitch = 1.0;
            utt.lang  = 'en-US';
            window.speechSynthesis.speak(utt);
            // Then speak syllables with pauses
            if (syllables) {
                var utt2 = new SpeechSynthesisUtterance(syllables.replace(/\|/g, ', '));
                utt2.rate  = 0.6;
                utt2.pitch = 0.9;
                utt2.lang  = 'en-US';
                window.speechSynthesis.speak(utt2);
            }
        }

