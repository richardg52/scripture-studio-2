        function searchTopicData(topic) {
            var el = document.getElementById('topicResults');
            if (!el) return;
            var topics = {
                faith:      { definition:'Firm belief in God and His promises, even without physical evidence.', passages:['Hebrews 11:1','Romans 10:17','Ephesians 2:8-9','James 2:14-17','Mark 11:22-24'], notes:'Faith is both a gift (Eph 2:8) and a discipline to be cultivated (Rom 10:17). Preach both aspects.' },
                love:       { definition:'The selfless, sacrificial concern for the well-being of others, rooted in God\'s own nature.', passages:['1 Corinthians 13:1-13','John 3:16','Romans 5:8','1 John 4:7-12','John 15:12-13'], notes:'Agape love (Greek) is unconditional. It is God\'s love and the standard for Christian love toward others.' },
                prayer:     { definition:'Communication with God — adoration, confession, thanksgiving, and supplication.', passages:['Matthew 6:9-13','Philippians 4:6-7','1 Thessalonians 5:17','Luke 18:1-8','James 5:16'], notes:'The ACTS model (Adoration, Confession, Thanksgiving, Supplication) provides excellent sermon structure.' },
                salvation:  { definition:'Deliverance from sin and its consequences through faith in Jesus Christ.', passages:['John 3:16-17','Romans 3:23','Romans 6:23','Ephesians 2:8-9','Acts 4:12'], notes:'Salvation involves justification (declared righteous), sanctification (being made holy), and glorification (final perfection).' },
                forgiveness:{ definition:'The act of pardoning an offense and releasing the offender from guilt or penalty.', passages:['Matthew 18:21-22','Colossians 3:13','Ephesians 4:32','Luke 23:34','Psalm 103:12'], notes:'Biblical forgiveness is both received from God and extended to others. The two are inseparably linked (Matthew 6:14-15).' },
                healing:    { definition:'Physical, emotional, or spiritual restoration, ultimately rooted in the redemptive work of Christ.', passages:['Isaiah 53:5','James 5:14-16','Matthew 4:23','Psalm 103:3','3 John 1:2'], notes:'Healing ministry involves prayer, community, medicine, and trust in God\'s sovereign timing.' },
                hope:       { definition:'Confident expectation in God\'s promises, especially regarding the future.', passages:['Romans 8:24-25','Hebrews 11:1','Romans 15:13','Lamentations 3:21-23','1 Peter 1:3'], notes:'Biblical hope is not wishful thinking — it is certainty grounded in the character and promises of God.' },
                marriage:   { definition:'The covenant union of husband and wife, designed by God as a reflection of Christ and the Church.', passages:['Genesis 2:24','Ephesians 5:22-33','1 Corinthians 7:3-5','Proverbs 18:22','Colossians 3:18-19'], notes:'Marriage sermons should address both the ideal and the grace available when marriages struggle.' },
                wisdom:     { definition:'The ability to apply knowledge and discernment in accordance with God\'s truth.', passages:['James 1:5','Proverbs 9:10','Proverbs 3:5-6','1 Corinthians 1:30','Ecclesiastes 12:13'], notes:'Wisdom in Scripture begins with the fear of the Lord (Prov 9:10) — not merely intellectual understanding.' },
