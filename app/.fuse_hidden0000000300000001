            const upcoming = events.filter(e => new Date(e.date + 'T23:59') >= new Date()).sort((a,b) => new Date(a.date) - new Date(b.date)).slice(0,10);
            if (upcoming.length === 0) {
                list.innerHTML = '<div style="text-align:center;color:#64748b;padding:2rem;">No upcoming events. Click "Add Event" to schedule something.</div>';
            } else {
                list.innerHTML = upcoming.map(e =>
                    '<div class="event-item ' + (e.type||'study') + '" style="display:flex;align-items:flex-start;gap:1rem;">' +
                    '<div class="event-time">' + new Date(e.date).toLocaleDateString('en-US',{month:'short',day:'numeric'}) + (e.time?' '+e.time:'') + '</div>' +
                    '<div class="event-details" style="flex:1;"><h4>' + e.title + '</h4>' + (e.description?'<p>'+e.description+'</p>':'') + '</div>' +
                    '<button onclick="deleteEvent(' + e.id + ')" style="background:none;border:none;color:#94a3b8;cursor:pointer;font-size:1.25rem;line-height:1;">&#215;</button></div>'
                ).join('');
