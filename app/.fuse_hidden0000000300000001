        function loadDevTemplate(name) {
            var templates = {
                '3-Point Sermon': 'TITLE: [Your Sermon Title]\nTEXT: [Scripture Reference]\nTHEME: [Central Truth]\n\nINTRODUCTION (3-5 min)\n- Hook: [Attention-grabbing story, stat, or question]\n- Bridge: [Connect to Scripture text]\n- Preview: Today we will see three truths from [text]...\n\nPOINT I: [Title]\n- Explanation: What does the text say?\n- Illustration: [Story or example]\n- Application: What does this mean for us?\n\nPOINT II: [Title]\n- Explanation:\n- Illustration:\n- Application:\n\nPOINT III: [Title]\n- Explanation:\n- Illustration:\n- Application:\n\nCONCLUSION (3-5 min)\n- Summary: Restate the three truths\n- Invitation: Call to specific response\n- Close: Memorable final statement',
                'Narrative Sermon': 'TITLE: [Your Sermon Title]\nTEXT: [Scripture Reference]\n\nOPENING SCENE (2 min)\n- Set the scene: time, place, characters\n- Establish the tension or need\n\nDEVELOPING TENSION (5-8 min)\n- Deepen the problem or conflict\n- Let the congregation feel the weight\n- Weave in contemporary parallels\n\nGOSPEL TURN (3-5 min)\n- How does God intervene?\n- The resolution found in Christ\n\nRESULTING TRANSFORMATION (3-5 min)\n- What changes because of this encounter?\n- What does this look like in daily life?\n\nAPPLICATION & CLOSE (3-5 min)\n- Your congregation is in this story\n- Specific response invited'
            };
            var text = templates[name] || '// Template: ' + name + '\n// Customize this framework for your message';
            openModal(name + ' Template',
                '<textarea style="width:100%;height:300px;font-family:monospace;font-size:0.85rem;padding:10px;border:1px solid #e2e8f0;border-radius:6px;resize:vertical">' + text + '</textarea>',
                function() {
                    if (navigator.clipboard) navigator.clipboard.writeText(text);
                    closeModal();
                    showToast('Template copied to clipboard');
                }
            );
            document.getElementById('modalAction').textContent = 'Copy to Clipboard';
        }

        function exportAllData() {
            var keys = ['ss_sermons','ss_prayers','ss_bookmarks','ss_highlights','ss_notes','ss_events','ss_members','ss_devotionals','ss_illustrations','ss_diary','ss_bible_studies','ss_preaching_events'];
            var data = {};
            keys.forEach(function(k){ data[k] = safeParse(k, []); });
            data.exported = new Date().toISOString();
            var blob = new Blob([JSON.stringify(data, null, 2)], {type:'application/json'});
            var url  = URL.createObjectURL(blob);
            var a    = document.createElement('a');
            a.href   = url;
            a.download = 'scripture-studio-backup-' + new Date().toISOString().split('T')[0] + '.json';
            a.click();
            URL.revokeObjectURL(url);
            showToast('Data exported successfully');
        }


