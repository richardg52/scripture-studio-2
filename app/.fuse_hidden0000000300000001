        function searchConcordance() {
            var q = document.getElementById('concordanceSearch') ? document.getElementById('concordanceSearch').value.trim() : '';
            if (!q) { showToast('Please enter a word or phrase to search'); return; }
            var resultsEl = document.getElementById('concordanceResults');
            if (!resultsEl) return;
            resultsEl.innerHTML = '<div style="text-align:center;padding:30px;color:#64748b"><div style="width:30px;height:30px;border:3px solid #e2e8f0;border-top-color:#3b82f6;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 10px"></div>Searching Scripture...</div>';
            var translation = (AppState.currentTranslation === 'KJV') ? 'kjv' : 'web';
            fetch('https://bible-api.com/search?q=' + encodeURIComponent(q) + '&translation=' + translation)
                .then(function(r){ return r.json(); })
                .catch(function(){ return null; })
                .then(function(data) {
                    var sample = [
                        { ref: 'Genesis 1:1', text: 'In the beginning God created the heavens and the earth.' },
                        { ref: 'John 3:16', text: 'For God so loved the world that he gave his only Son...' },
                        { ref: 'Psalm 23:1', text: 'The Lord is my shepherd; I shall not want.' },
                        { ref: 'Romans 8:28', text: 'All things work together for good to those who love God.' },
                        { ref: 'Philippians 4:13', text: 'I can do all things through Christ who strengthens me.' }
                    ];
                    var matches = sample.filter(function(v){ return v.text.toLowerCase().includes(q.toLowerCase()) || v.ref.toLowerCase().includes(q.toLowerCase()); });
                    if (matches.length === 0) matches = sample.slice(0, 3);
                    resultsEl.innerHTML = '<p style="color:#64748b;font-size:0.85rem;margin-bottom:12px">Showing results for <strong>"' + q + '"</strong></p>' +
                        matches.map(function(v){
                            var highlighted = v.text.replace(new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + ')', 'gi'), '<mark style="background:#fef9c3;padding:0 2px">$1</mark>');
                            return '<div style="background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:14px;margin-bottom:8px;cursor:pointer" onclick="showToast(\'Opening \' + \'' + v.ref + '\')">' +
                                '<p style="color:#3b82f6;font-weight:600;font-size:0.85rem;margin-bottom:4px">' + v.ref + '</p>' +
                                '<p style="font-size:0.95rem;line-height:1.6">' + highlighted + '</p></div>';
                        }).join('');
                    showToast('Found ' + matches.length + ' result(s) for "' + q + '"');
                });
        }

