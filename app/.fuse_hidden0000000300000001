        // ============================================================
        // NAVIGATION
        // ============================================================
        function navigateTo(page) {
            if (!page) return;
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            const pageEl = document.getElementById('page-' + page);
            if (pageEl) pageEl.classList.add('active');
            const navEl = document.querySelector('.nav-item[data-page="' + page + '"]');
            if (navEl) navEl.classList.add('active');
            AppState.currentPage = page;
            const titleEl = document.getElementById('pageTitle');
            if (titleEl) titleEl.textContent = pageTitles[page] || page;
            window.scrollTo(0,0);
            closeVerseActions();
            // Page-specific loaders
            const loaders = {
                'prayer-journal':       loadPrayers,
                'devotional':           loadDevotionals,
                'bookmarks':            loadBookmarks,
                'highlights':           loadHighlights,
                'notes':                loadNotes,
                'congregation':         loadMembers,
                'calendar':             function() { renderCalendar(); loadEvents(); },
                'sermon-builder':       function() {
                    var sd = document.getElementById('sermonDate');
                    if (sd && !sd.value) sd.value = new Date().toISOString().split('T')[0];
                },
                'illustrations':        function() { loadIllustrations('all'); },
                'preaching-calendar':   function() { loadPreachingCalendar('upcoming'); },
                'bible-study-builder':  function() { loadStudies('all'); },
                'personal-diary':       function() { loadDiary('all'); },
                'homegoing-builder':    function() { loadHomegoingSection('message', document.querySelector('.hg-tab')); },
                'commentaries':         function() { populateCommentaryBooks(); setTimeout(function(){ var ref = AppState.currentBook + ' ' + AppState.currentChapter; if(ref.trim() !== '') { loadCommentaryBibleText(ref); loadCommentary('bishops', document.querySelector('.commentary-tab.active')); } }, 80); },
                'development-studio':   function() { loadDevStudio('templates', document.querySelector('.dev-tab')); },
                'lexicon':              function() { searchLexicon(); },
                'heb-greek-lexicon':    function() { searchHGLex(); },
                'topical-finder':       function() {
                    var el = document.getElementById('topicResults');
                    if (el) el.innerHTML = '<p style="color:#94a3b8;text-align:center;padding:20px;font-size:0.9rem">Click a topic above or type one to search</p>';
                },
                'pronunciation-tool':   function() {
                    var el = document.getElementById('pronunciationResult');
                    if (el) el.innerHTML = '<p style="color:#94a3b8;text-align:center;padding:20px;font-size:0.9rem">Click a word above or type one to look it up</p>';
                },
                'reading-plans':        function() { loadReadingPlans(); },
                'hymnal':               function() { loadHymnal(); },
                'word-study':           function() {
                    var el = document.getElementById('wordStudyResults');
                    if (el) el.innerHTML = '<p style="color:#94a3b8;text-align:center;padding:20px;font-size:0.9rem">Type a word above and click Study</p>';
                }
            };
            if (loaders[page]) loaders[page]();
            if (window.innerWidth <= 768)
                document.querySelector('.sidebar').style.transform = 'translateX(-100%)';
        }

        function toggleSidebar() {
            const s = document.querySelector('.sidebar');
            s.style.transform = s.style.transform === 'translateX(-100%)' ? 'translateX(0)' : 'translateX(-100%)';
        }

        // ============================================================
        // BIBLE READER
        // ============================================================
        function populateBookSelect() {
            const sel = document.getElementById('bookSelect');
            if (!sel) return;
            sel.innerHTML = '';
            bibleBooks.forEach(b => {
                const o = document.createElement('option');
                o.value = b.name; o.textContent = b.name;
                if (b.name === AppState.currentBook) o.selected = true;
                sel.appendChild(o);
            });
        }

        function updateChapterSelect() {
            const bookName = document.getElementById('bookSelect') ? document.getElementById('bookSelect').value : AppState.currentBook;
            AppState.currentBook = bookName;
            const book = bibleBooks.find(b => b.name === bookName);
            if (!book) return;
            const sel = document.getElementById('chapterSelect');
            if (!sel) return;
            sel.innerHTML = '';
            for (let i = 1; i <= book.chapters; i++) {
                const o = document.createElement('option');
                o.value = i; o.textContent = 'Chapter ' + i;
                if (i === AppState.currentChapter) o.selected = true;
                sel.appendChild(o);
            }
        }

        async function loadChapter() {
            const bookSel = document.getElementById('bookSelect');
            const chapSel = document.getElementById('chapterSelect');
            const transSel = document.getElementById('translationSelect');
            if (bookSel) AppState.currentBook = bookSel.value;
            if (chapSel) AppState.currentChapter = parseInt(chapSel.value) || 1;
            if (transSel) AppState.currentTranslation = transSel.value;

            const title = document.getElementById('chapterTitle');
            const container = document.getElementById('versesContainer');
            if (!container) return;
            if (title) title.textContent = AppState.currentBook + ' ' + AppState.currentChapter;
            container.innerHTML = '<div style="text-align:center;padding:2rem;color:#64748b;"><div style="width:32px;height:32px;border:3px solid #3b82f6;border-top-color:transparent;border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 1rem;"></div>Loading...</div>';

            const transMap = {KJV:'kjv',NKJV:'kjv',ASV:'kjv',WEB:'web',ESV:'web',NIV:'web',NASB:'web',NLT:'web',CSB:'web',NRSV:'web',AMP:'web',MSG:'web',TPT:'web'};
            const trans = transMap[AppState.currentTranslation] || 'kjv';
            const bookApi = encodeURIComponent(AppState.currentBook);

            try {
                const resp = await fetch('https://bible-api.com/' + bookApi + '+' + AppState.currentChapter + '?translation=' + trans);
                const data = await resp.json();
                container.innerHTML = '';
                if (data.verses && data.verses.length > 0) {
                    const highlights = getHighlights();
                    data.verses.forEach(v => {
                        const el = document.createElement('div');
                        el.className = 'verse';
                        el.dataset.verse = v.verse;
                        el.id = 'verse-' + v.verse;
                        const key = AppState.currentBook + '-' + AppState.currentChapter + '-' + v.verse;
                        const hl = highlights.find(h => h.key === key);
                        if (hl) el.classList.add('highlight-' + hl.color);
                        el.innerHTML = '<span class="verse-number">' + v.verse + '</span><span class="verse-text">' + v.text.trim() + '</span>';
                        el.addEventListener('click', () => selectVerse(el, v.verse, v.text.trim()));
                        container.appendChild(el);
                    });
                    const stats = getStats();
                    stats.chaptersRead = (stats.chaptersRead || 0) + 1;
                    stats.streak = (stats.streak || 0) + 1;
                    saveStats(stats);
                    updateDashboardStats();
                    addActivity('Read ' + AppState.currentBook + ' ' + AppState.currentChapter);
                } else {
                    container.innerHTML = '<p style="padding:1.5rem;color:#64748b;">Could not load chapter. Check your internet connection.</p>';
                }
            } catch(err) {
                container.innerHTML = '<p style="padding:1.5rem;color:#64748b;">Unable to load &#8212; please check your internet connection and try again.</p>';
            }
        }

        function previousChapter() {
            if (AppState.currentChapter > 1) {
                AppState.currentChapter--;
                if (document.getElementById('chapterSelect')) document.getElementById('chapterSelect').value = AppState.currentChapter;
                loadChapter();
            } else {
                const idx = bibleBooks.findIndex(b => b.name === AppState.currentBook);
                if (idx > 0) {
                    AppState.currentBook = bibleBooks[idx-1].name;
                    AppState.currentChapter = bibleBooks[idx-1].chapters;
                    if (document.getElementById('bookSelect')) document.getElementById('bookSelect').value = AppState.currentBook;
                    updateChapterSelect();
                    loadChapter();
                }
            }
        }

        function nextChapter() {
            const book = bibleBooks.find(b => b.name === AppState.currentBook);
            if (book && AppState.currentChapter < book.chapters) {
                AppState.currentChapter++;
                if (document.getElementById('chapterSelect')) document.getElementById('chapterSelect').value = AppState.currentChapter;
                loadChapter();
            } else {
                const idx = bibleBooks.findIndex(b => b.name === AppState.currentBook);
                if (idx < bibleBooks.length - 1) {
                    AppState.currentBook = bibleBooks[idx+1].name;
                    AppState.currentChapter = 1;
                    if (document.getElementById('bookSelect')) document.getElementById('bookSelect').value = AppState.currentBook;
                    updateChapterSelect();
                    loadChapter();
                }
            }
        }

        function selectVerse(el, number, text) {
            document.querySelectorAll('.verse.selected').forEach(v => v.classList.remove('selected'));
            el.classList.add('selected');
            selectedVerseData = {el, number, text, book:AppState.currentBook, chapter:AppState.currentChapter};
            AppState.selectedVerseEl = el;
            const bar = document.getElementById('verseActions');
            if (bar) {
                bar.style.display = 'flex';
                const rect = el.getBoundingClientRect();
                bar.style.top = (rect.bottom + window.scrollY + 8) + 'px';
            }
        }

        function closeVerseActions() {
            const bar = document.getElementById('verseActions');
            if (bar) bar.style.display = 'none';
            if (AppState.selectedVerseEl) AppState.selectedVerseEl.classList.remove('selected');
            selectedVerseData = null;
            AppState.selectedVerseEl = null;
        }

        function highlightVerse(color) {
            if (!selectedVerseData) return;
            const key = selectedVerseData.book + '-' + selectedVerseData.chapter + '-' + selectedVerseData.number;
            const highlights = getHighlights().filter(h => h.key !== key);
            highlights.push({key, color, book:selectedVerseData.book, chapter:selectedVerseData.chapter, verse:selectedVerseData.number, text:selectedVerseData.text, date:new Date().toISOString()});
            saveHighlights(highlights);
            ['yellow','green','blue','pink','orange'].forEach(c => selectedVerseData.el.classList.remove('highlight-'+c));
            selectedVerseData.el.classList.add('highlight-' + color);
            closeVerseActions();
            showToast('Verse highlighted!');
        }

        function bookmarkVerse() {
            if (!selectedVerseData) return;
            const key = selectedVerseData.book + '-' + selectedVerseData.chapter + '-' + selectedVerseData.number;
            const bookmarks = getBookmarks();
            if (!bookmarks.find(b => b.key === key)) {
                bookmarks.push({key, book:selectedVerseData.book, chapter:selectedVerseData.chapter, verse:selectedVerseData.number, text:selectedVerseData.text, date:new Date().toISOString()});
                saveBookmarks(bookmarks);
                showToast('Verse bookmarked!');
            } else {
                showToast('Already bookmarked');
            }
            closeVerseActions();
        }

        function addNoteToVerse() {
            if (!selectedVerseData) return;
            const ref = selectedVerseData.book + ' ' + selectedVerseData.chapter + ':' + selectedVerseData.number;
            const verseText = selectedVerseData.text;
            openModal('Add Study Note',
                '<div class="form-group"><label class="form-label">Reference</label>' +
                '<input type="text" class="form-input" id="noteRef" value="' + ref + '" readonly></div>' +
                '<div class="form-group"><p style="font-style:italic;color:#64748b;font-size:0.9rem;padding:0.75rem;background:#f8fafc;border-radius:6px;">"' + verseText + '"</p></div>' +
                '<div class="form-group"><label class="form-label">Your Note</label>' +
                '<textarea class="form-textarea" id="noteContent" placeholder="Enter your study note..." style="min-height:120px;"></textarea></div>',
                function() {
                    const content = document.getElementById('noteContent').value.trim();
                    if (!content) return showToast('Please enter a note');
                    const notes = getNotes();
                    notes.push({id:Date.now(), ref, text:verseText, content, date:new Date().toISOString()});
                    saveNotes(notes);
                    closeModal();
                    closeVerseActions();
                    showToast('Note saved!');
                }
            );
        }

        function copyVerse() {
            if (!selectedVerseData) return;
            const text = '"' + selectedVerseData.text + '" \u2014 ' + selectedVerseData.book + ' ' + selectedVerseData.chapter + ':' + selectedVerseData.number + ' (' + AppState.currentTranslation + ')';
            if (navigator.clipboard) {
                navigator.clipboard.writeText(text).then(() => showToast('Verse copied!')).catch(() => fallbackCopy(text));
            } else { fallbackCopy(text); }
            closeVerseActions();
        }

        function fallbackCopy(text) {
            const ta = document.createElement('textarea');
            ta.value = text;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            showToast('Verse copied!');
        }

        function goToVerse(book, chapter) {
            AppState.currentBook = book;
            AppState.currentChapter = parseInt(chapter);
            if (document.getElementById('bookSelect')) document.getElementById('bookSelect').value = book;
            updateChapterSelect();
            if (document.getElementById('chapterSelect')) document.getElementById('chapterSelect').value = chapter;
            loadChapter();
            navigateTo('bible-reader');
        }

        // ============================================================
        // BOOKMARKS
        // ============================================================
        function loadBookmarks() {
            const bmarks = getBookmarks();
            const list = document.getElementById('bookmarksList');
            if (!list) return;
            if (bmarks.length === 0) {
                list.innerHTML = '<div class="empty-state"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"></path></svg><h3>No Bookmarks Yet</h3><p>Select a verse in the Bible Reader and tap Bookmark</p></div>';
                return;
            }
            list.innerHTML = bmarks.map(b =>
                '<div style="padding:1.25rem;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;margin-bottom:0.75rem;display:flex;align-items:flex-start;gap:1rem;">' +
                '<div style="flex:1;"><div style="font-weight:600;color:#1e40af;">' + b.book + ' ' + b.chapter + ':' + b.verse + '</div>' +
                '<div style="font-style:italic;color:#4b5563;margin-top:0.25rem;font-size:0.95rem;">"' + b.text + '"</div>' +
                '<div style="font-size:0.8rem;color:#94a3b8;margin-top:0.5rem;">' + new Date(b.date).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) + '</div></div>' +
                '<div style="display:flex;gap:0.5rem;flex-shrink:0;">' +
                '<button class="btn btn-secondary btn-sm" onclick="goToVerse(\'' + b.book + '\',' + b.chapter + ')">Open</button>' +
                '<button class="btn btn-secondary btn-sm" onclick="removeBookmark(\'' + b.key + '\')">Remove</button></div></div>'
            ).join('');
        }

        function removeBookmark(key) {
            saveBookmarks(getBookmarks().filter(b => b.key !== key));
            loadBookmarks();
            showToast('Bookmark removed');
        }

        // ============================================================
        // HIGHLIGHTS
        // ============================================================
        function loadHighlights() {
            renderHighlights(getHighlights());
        }

        function filterHighlights(color) {
            const all = getHighlights();
            renderHighlights(color === 'all' ? all : all.filter(h => h.color === color));
        }

        function renderHighlights(highlights) {
            const list = document.getElementById('highlightsList');
            if (!list) return;
            const hexMap = {yellow:'#fbbf24',green:'#22c55e',blue:'#3b82f6',pink:'#ec4899',orange:'#f97316'};
            if (highlights.length === 0) {
                list.innerHTML = '<div class="empty-state"><h3>No Highlights</h3><p>Select a verse and choose a color to highlight it</p></div>';
                return;
            }
            list.innerHTML = highlights.map(h =>
                '<div style="padding:1.25rem;background:#f8fafc;border-radius:12px;border-left:4px solid ' + (hexMap[h.color]||'#94a3b8') + ';margin-bottom:0.75rem;display:flex;align-items:flex-start;gap:1rem;">' +
                '<div style="flex:1;"><div style="font-weight:600;">' + h.book + ' ' + h.chapter + ':' + h.verse + '</div>' +
                '<div style="font-style:italic;color:#4b5563;margin-top:0.25rem;">"' + h.text + '"</div></div>' +
                '<div style="display:flex;gap:0.5rem;">' +
                '<button class="btn btn-secondary btn-sm" onclick="goToVerse(\'' + h.book + '\',' + h.chapter + ')">Open</button>' +
                '<button class="btn btn-secondary btn-sm" onclick="removeHighlight(\'' + h.key + '\')">Remove</button></div></div>'
            ).join('');
        }

        function removeHighlight(key) {
            saveHighlights(getHighlights().filter(h => h.key !== key));
            loadHighlights();
            showToast('Highlight removed');
        }

        // ============================================================
        // NOTES
        // ============================================================
        function loadNotes() {
            const notes = getNotes();
            const list = document.getElementById('notesList');
            if (!list) return;
            if (notes.length === 0) {
                list.innerHTML = '<div class="empty-state"><h3>No Notes</h3><p>Tap a verse in the Bible Reader and select "Note" to add a study note</p></div>';
                return;
            }
            list.innerHTML = notes.map(n =>
                '<div style="padding:1.25rem;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;margin-bottom:0.75rem;">' +
                '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.5rem;">' +
                '<div style="font-weight:600;color:#1e40af;">' + n.ref + '</div>' +
                '<button onclick="deleteNote(' + n.id + ')" style="background:none;border:none;color:#94a3b8;cursor:pointer;font-size:1.25rem;line-height:1;">&#215;</button></div>' +
                (n.text ? '<div style="font-style:italic;color:#64748b;font-size:0.9rem;margin-bottom:0.5rem;">"' + n.text + '"</div>' : '') +
                '<div style="color:#1e293b;line-height:1.7;">' + n.content + '</div>' +
                '<div style="font-size:0.8rem;color:#94a3b8;margin-top:0.5rem;">' + new Date(n.date).toLocaleDateString() + '</div></div>'
            ).join('');
        }

        function showNewNoteModal() {
            openModal('New Study Note',
                '<div class="form-group"><label class="form-label">Reference</label><input type="text" class="form-input" id="newNoteRef" placeholder="e.g., John 3:16"></div>' +
                '<div class="form-group"><label class="form-label">Note</label><textarea class="form-textarea" id="newNoteContent" style="min-height:120px;" placeholder="Your study note..."></textarea></div>',
                function() {
                    const ref = document.getElementById('newNoteRef').value.trim();
                    const content = document.getElementById('newNoteContent').value.trim();
                    if (!ref || !content) return showToast('Please fill in all fields');
                    const notes = getNotes();
                    notes.push({id:Date.now(), ref, text:'', content, date:new Date().toISOString()});
                    saveNotes(notes);
                    closeModal();
                    loadNotes();
                    showToast('Note saved!');
                }
            );
        }

        function deleteNote(id) {
            saveNotes(getNotes().filter(n => n.id !== id));
            loadNotes();
            showToast('Note deleted');
        }

        // ============================================================
        // SERMON BUILDER
        // ============================================================
        function updateWordCount() {
            const content = document.getElementById('sermonContent');
            if (!content) return;
            const text = content.innerText || '';
            const words = text.trim() ? text.trim().split(/\s+/).length : 0;
            if (document.getElementById('wordCount')) document.getElementById('wordCount').textContent = words;
            if (document.getElementById('speakingTime')) document.getElementById('speakingTime').textContent = Math.ceil(words / 130);
        }

        function formatText(cmd) {
            document.execCommand(cmd, false, null);
            const c = document.getElementById('sermonContent');
            if (c) c.focus();
        }

        function saveSermon() {
            const title = document.getElementById('sermonTitle').value.trim();
            const scripture = document.getElementById('sermonScripture').value.trim();
            const date = document.getElementById('sermonDate').value;
            const content = document.getElementById('sermonContent').innerHTML;
            if (!title) return showToast('Please enter a sermon title');
            const sermons = getSermons();
            const idx = sermons.findIndex(s => s.id === AppState.editingSermonId);
            const sermon = {id: AppState.editingSermonId || Date.now(), title, scripture, date, content, updated: new Date().toISOString()};
            if (idx >= 0) sermons[idx] = sermon;
            else { sermons.push(sermon); AppState.editingSermonId = sermon.id; }
            saveSermons(sermons);
            updateDashboardStats();
            addActivity('Saved sermon: "' + title + '"');
            showToast('Sermon saved!');
        }

        function loadSermonsList() {
            const panel = document.getElementById('sermonsListPanel');
            const list = document.getElementById('sermonsList');
            if (!panel || !list) return;
            const sermons = getSermons();
            if (sermons.length === 0) {
                list.innerHTML = '<div class="empty-state"><p>No saved sermons yet.</p></div>';
            } else {
                list.innerHTML = sermons.map(s =>
                    '<div style="display:flex;align-items:center;gap:1rem;padding:1rem;background:#f8fafc;border-radius:8px;border:1px solid #e2e8f0;margin-bottom:0.5rem;">' +
                    '<div style="flex:1;"><div style="font-weight:600;">' + s.title + '</div>' +
                    '<div style="font-size:0.85rem;color:#64748b;">' + (s.scripture||'No reference') + ' &middot; ' + (s.date||'No date') + '</div></div>' +
                    '<div style="display:flex;gap:0.5rem;">' +
                    '<button class="btn btn-primary btn-sm" onclick="loadSermon(' + s.id + ')">Load</button>' +
                    '<button class="btn btn-secondary btn-sm" onclick="deleteSermon(' + s.id + ')">Delete</button></div></div>'
                ).join('');
            }
            panel.style.display = 'block';
        }

        function loadSermon(id) {
            const s = getSermons().find(s => s.id === id);
            if (!s) return;
            document.getElementById('sermonTitle').value = s.title;
            document.getElementById('sermonScripture').value = s.scripture || '';
            document.getElementById('sermonDate').value = s.date || '';
            document.getElementById('sermonContent').innerHTML = s.content || '';
            AppState.editingSermonId = s.id;
            updateWordCount();
            document.getElementById('sermonsListPanel').style.display = 'none';
            showToast('Sermon loaded!');
        }

        function deleteSermon(id) {
            saveSermons(getSermons().filter(s => s.id !== id));
            loadSermonsList();
            showToast('Sermon deleted');
        }

        // ============================================================
        // AI SERMON GENERATOR
        // ============================================================
        function generateSermon() {
            const scripture = document.getElementById('aiScripture').value.trim();
            const topic = document.getElementById('aiTopic').value.trim();
            const length = document.getElementById('aiLength').value;
            const audience = document.getElementById('aiAudience').value;
            const instructions = document.getElementById('aiInstructions').value.trim();
            if (!scripture) return showToast('Please enter a scripture passage');
            document.getElementById('aiLoading').style.display = 'flex';
            document.getElementById('aiResult').style.display = 'none';
            setTimeout(function() {
                const lenMap = {short:'15-20 minutes',medium:'25-35 minutes',long:'40-50 minutes'};
                const audMap = {general:'General Congregation',youth:'Youth & Young Adults',men:"Men\'s Ministry",women:"Women\'s Ministry",seekers:'Seekers & Unbelievers'};
                const ptCount = length === 'short' ? 2 : length === 'medium' ? 3 : 4;
                const mainTopic = topic || 'Faith, Obedience & Grace';
                const pts = [
                    {h:'The Context: Setting the Stage', b:'Begin by grounding your audience in the historical and literary context of ' + scripture + '. Who wrote it? To whom? Under what circumstances? A strong contextual foundation makes everything that follows more powerful and believable.'},
                    {h:'The Central Truth: What God Is Saying', b:'Draw out the primary theological theme of this passage. Show how it reveals God\'s character, His promises, and His plan for His people. Connect it to the larger narrative of Scripture, pointing toward Christ.'},
                    {h:'Personal Application: What This Means for Us Today', b:'Bridge the ancient text to present-day life for your ' + audMap[audience] + '. Offer specific, practical steps your congregation can take this week in response to what God is saying through this passage.'},
                    {h:'The Call to Action: Responding to God\'s Word', b:'Issue a clear, compelling invitation. Whether for salvation, rededication, or deeper commitment &#8212; give your congregation a concrete way to respond to the Word of God they have just heard.'}
                ].slice(0, ptCount);
                const outline = '<h2 style="color:#1e3a5f;margin-bottom:0.5rem;">' + mainTopic + '</h2>' +
                    '<p style="color:#64748b;margin-bottom:0.5rem;font-size:0.9rem;"><strong>Text:</strong> ' + scripture + ' &nbsp;|&nbsp; <strong>Audience:</strong> ' + audMap[audience] + ' &nbsp;|&nbsp; <strong>Length:</strong> ' + lenMap[length] + '</p>' +
                    (instructions ? '<p style="color:#64748b;font-size:0.9rem;margin-bottom:1rem;"><strong>Instructions:</strong> ' + instructions + '</p>' : '') +
                    '<hr style="margin:1rem 0;border:none;border-top:1px solid #e2e8f0;">' +
                    '<h3 style="color:#1e3a5f;">Introduction <span style="font-weight:400;font-size:0.9rem;color:#64748b;">(2-3 min)</span></h3>' +
                    '<p style="margin-bottom:1rem;line-height:1.7;">Open with a compelling story or question that connects with your audience\'s daily life. Bridge to your text: <em>"Today we look at ' + scripture + ', and I believe God has a specific word for each of us..."</em></p>' +
                    pts.map((p,i) => '<h3 style="color:#1e3a5f;margin-top:1.5rem;">Point ' + (i+1) + ': ' + p.h + '</h3><p style="line-height:1.7;margin-bottom:0.75rem;">' + p.b + '</p><p style="color:#64748b;font-size:0.9rem;font-style:italic;">&#128161; <strong>Illustration:</strong> [Insert a personal story, biblical example, or real-world illustration here]</p>').join('') +
                    '<h3 style="color:#1e3a5f;margin-top:1.5rem;">Conclusion <span style="font-weight:400;font-size:0.9rem;color:#64748b;">(3-5 min)</span></h3>' +
                    '<p style="line-height:1.7;">Bring all your points together. Return to your opening illustration. Give one memorable takeaway sentence. Issue your altar call or invitation. Close in prayer.</p>' +
                    '<div style="margin-top:1.5rem;padding:1rem;background:#f0f9ff;border-radius:8px;border-left:4px solid #3b82f6;">' +
                    '<p style="font-size:0.85rem;color:#64748b;margin:0;"><em>Generated by Scripture Studio AI &middot; Bishop Richard G. Clark\'s Expository Method</em></p></div>';
                document.getElementById('aiLoading').style.display = 'none';
                document.getElementById('aiResult').style.display = 'block';
                document.getElementById('aiResultTitle').textContent = mainTopic + ' \u2014 ' + scripture;
                document.getElementById('aiResultContent').innerHTML = outline;
                addActivity('Generated AI sermon for ' + scripture);
            }, 1800);
        }

        function copyAiResult() {
            const c = document.getElementById('aiResultContent');
            if (!c) return;
            if (navigator.clipboard) navigator.clipboard.writeText(c.innerText).then(() => showToast('Sermon outline copied!')).catch(() => showToast('Copy failed'));
            else fallbackCopy(c.innerText);
        }

        function sendToSermonBuilder() {
            const title = document.getElementById('aiResultTitle').textContent;
            const content = document.getElementById('aiResultContent').innerHTML;
            const scripture = document.getElementById('aiScripture').value;
            if (document.getElementById('sermonTitle')) document.getElementById('sermonTitle').value = title;
            if (document.getElementById('sermonScripture')) document.getElementById('sermonScripture').value = scripture;
            if (document.getElementById('sermonContent')) document.getElementById('sermonContent').innerHTML = content;
            AppState.editingSermonId = null;
            updateWordCount();
            navigateTo('sermon-builder');
            showToast('Loaded in Sermon Builder!');
        }

        // ============================================================
        // AI COMMENTARY (BISHOP'S)
        // ============================================================
        // ── Passage-specific commentary database ──────────────────────────
        var PASSAGE_DB = {
          'genesis 1':    {ov:'Genesis 1 is a theological manifesto, not merely a scientific account. Ten times "God said" — ten times it was so. Moses is systematically dismantling the gods of Egypt and Babylon: the sun is not a deity, it is a lamp God hung in the sky. The sea is not chaos — it is waters God gathered. Every act of creation is ordered, purposeful, and declared very good. The God who spoke worlds into existence is the same God who speaks into the dark places of your congregation\'s lives today.',xr:'John 1:1-3; Colossians 1:16; Hebrews 11:3; Psalm 33:6; Isaiah 40:28',th:'Creation ex nihilo — God made all things out of nothing by His word alone. This establishes His absolute sovereignty and the complete dependence of every creature on the Creator. Every doctrine of Scripture rests on this foundation: a God who speaks and it is done.',ap:'Remind your congregation: the same God who said "Let there be light" can speak light into their darkest situation. Nothing exists outside His authority. Nothing in their lives is beyond His power to redeem and order for His glory.'},
          'genesis 3':    {ov:'The hinge of all human history. The Serpent\'s strategy — "Did God really say?" — is unchanged today. Eve\'s progression: she saw, she desired, she took, she gave. Sin always follows that sequence. But hidden inside judgment is verse 15: the first gospel announcement. The seed of the woman will crush the Serpent\'s head. You cannot preach Genesis 3 without pointing to Calvary — this chapter demands it.',xr:'Romans 5:12-21; 1 Corinthians 15:22; Revelation 12:9; Galatians 4:4; Hebrews 2:14',th:'The Fall introduces four ruptures: between humanity and God (shame and hiding), within the human heart (guilt), between man and woman (blame-shifting), and between humanity and creation (thorns and toil). Christ\'s redemption systematically addresses every one of these fractures.',ap:'Help your people recognize the Serpent\'s voice — it always begins with a question about God\'s Word, then contradicts it, then offers a counterfeit. Teach them to answer temptation the way Jesus did: "It is written."'},
          'genesis 12':   {ov:'The pivot of all redemptive history. God calls Abram — a pagan from Ur — with five "I will" statements and zero explanations. This is faith in its purest form: obeying a voice you\'ve just met, leaving everything familiar, heading to a destination you\'ve never seen. The blessing flows through Abram to all families of the earth. That ultimate blessing is Jesus Christ (Galatians 3:16).',xr:'Galatians 3:8-16; Romans 4:1-5; Hebrews 11:8-10; Acts 3:25; John 8:56',th:'The Abrahamic covenant — land, seed, and blessing — is the structural backbone of all biblical theology. Paul declares that God preached the gospel beforehand to Abraham in this very text (Galatians 3:8). Everything from Moses to Malachi to Messiah flows from this chapter.',ap:'God fills us to overflow to others. Abram was not blessed to hoard the blessing — he was blessed to be a blessing. Ask your congregation: who in your sphere of influence needs what God has poured into you?'},
          'genesis 22':   {ov:'The greatest chapter in the Old Testament. Isaac carries the wood — just as Jesus carried the cross. Abraham raises the knife, fully intending to obey. God stops him: "I myself will provide the lamb." The ram caught in the thicket is substitution — life given in the place of another. Notice: God the Father did not stop His own hand when His Son hung on the cross. He provided Himself as the Lamb.',xr:'John 3:16; Hebrews 11:17-19; Romans 8:32; Revelation 5:6; Isaiah 53:7',th:'Jehovah-Jireh — "the LORD will provide" — emerges from Moriah. Every provision in Scripture traces back here. Substitutionary atonement is not a New Testament invention; it was enacted dramatically on this mountain 2,000 years before Calvary.',ap:'Three days of silence (v.4) — Abraham walked in faith while his heart broke. Your congregation faces their own three-day silences when God is quiet and the knife is raised. Tell them: God\'s provision arrives exactly when needed, never a moment before, never a moment after.'},
          'psalm 1':      {ov:'The gateway to the entire Psalter. Two trees, two roads, two destinies. The blessed man does not walk in the counsel of the wicked — "walk" describes direction and lifestyle, not a single step. He delights in God\'s Word and meditates — the Hebrew means to chew on it like a cow chews cud, drawing out every nutrient. You become what you meditate on. Your congregation is being formed by something — make sure it is the Word.',xr:'Joshua 1:8; Jeremiah 17:7-8; Matthew 7:24-27; Revelation 22:2; John 15:5',th:'Psalm 1 presents two destinies determined by one choice: where you direct your attention and affection. The tree by the river is not striving — it is simply staying connected to the water source. Spiritual fruitfulness is not an achievement; it is the result of abiding.',ap:'Challenge your people: what are they meditating on? What voices shape their inner world Monday through Saturday? The most formative spiritual discipline is not what happens in a church service; it is what occupies the mind in the quiet moments of ordinary life.'},
          'psalm 23':     {ov:'This is not merely a funeral psalm — it is a warrior\'s psalm. David was a shepherd; he knew the rod was for fighting wolves. "The valley of the shadow of death" in Hebrew is tsalmaveth — deep, terrifying darkness. This is real danger, not poetic metaphor. The table set in the presence of enemies is defiant worship: God blesses you right in front of your adversary. The Shepherd leads through valleys, not around them.',xr:'John 10:11-14; Ezekiel 34:11-16; Isaiah 40:11; Hebrews 13:20; 1 Peter 5:4',th:'The shift from third person (vv.1-3, "He leads me") to second person (v.4, "You are with me") at the valley of darkness is the theological heart of the psalm: when danger intensifies, abstract doctrine becomes intimate communion. God is not a concept in the valley — He is a Companion.',ap:'Tell your congregation the Shepherd\'s guarantee is not a life free of valleys — it is a life with a faithful Companion through them. Goodness and mercy are not accidents; they are a divine honor guard assigned to escort every child of God through every day of their lives.'},
          'psalm 51':     {ov:'The anatomy of genuine repentance. David wrote this after Nathan confronted him about Bathsheba and Uriah. Notice what he does not do: no deflecting, no minimizing, no blame-shifting. He owns it completely: "Against you, you only, have I sinned." Three Hebrew words cover every angle of moral failure: pesha (rebellion), avon (twisted nature), hatta (missing the mark). This is the prayer your brokenhearted congregation needs to pray.',xr:'2 Samuel 12:1-13; Romans 3:23; 1 John 1:9; Isaiah 1:18; Micah 7:18-19',th:'"Create in me a clean heart" uses the Hebrew bara — the word for creation ex nihilo. David is not asking for renovation; he is asking for a brand-new creation. This anticipates the New Testament doctrine of regeneration: genuine renewal is not self-improvement, it is divine re-creation (2 Corinthians 5:17).',ap:'Teach your congregation the difference between remorse and repentance. Remorse says "I am sorry I got caught." Repentance says "Against You, You only, have I sinned." One looks at consequences; the other looks at God. Only one produces a broken and contrite heart that God will not despise.'},
          'psalm 91':     {ov:'The soldier\'s psalm, the midnight psalm, the hospital psalm. "He who dwells" — the Hebrew suggests habitual residence, not a vacation. The protection promised here is for those who have made God their permanent address. Satan himself quoted verses 11-12 when tempting Jesus in the wilderness — which tells you how powerful this psalm is, and that even Scripture can be twisted by those who omit crucial phrases like "in all your ways."',xr:'Matthew 4:6; Deuteronomy 33:27; Isaiah 43:2; Hebrews 1:14; Daniel 6:22',th:'The Psalm lists eight forms of divine protection: the fowler\'s snare, deadly pestilence, the terror of night, the arrow by day, the plague, the destruction at noon, the stumbling stone, and the venomous beast. The protection is comprehensive, covenantal, and conditioned on dwelling in God\'s presence.',ap:'Verse 2 is the key: "I will say of the LORD, He is my refuge." This is a spoken confession in the darkness. Teach your people to confess Scripture over their fears out loud. What you say about God in your darkest moment shapes what you experience of God in that moment.'},
          'isaiah 53':    {ov:'Written 700 years before Calvary, this reads like an eyewitness account of the crucifixion. "He was pierced for our transgressions" — our. The prophet uses the plural deliberately: the Servant bears what we deserved. This is the chapter the Ethiopian eunuch was reading when Philip found him (Acts 8). It still brings people to Christ. No sermon on the atonement is complete without Isaiah 53.',xr:'Acts 8:32-35; 1 Peter 2:22-25; Matthew 8:17; Romans 4:25; John 12:38',th:'The word asham (v.10, "guilt offering") is a precise sacrificial term from Leviticus. The Servant\'s death is not moral example or inspirational influence — it is penal substitution: the innocent bearing the penalty owed by the guilty. The Servant "sees his offspring" after being "cut off from the land of the living" — implying resurrection, centuries before the empty tomb.',ap:'Walk your congregation through each phrase deliberately: "despised and rejected" — Jesus was not impressive to the casual observer. "Man of sorrows and acquainted with grief" — the Son of God knows grief personally, from the inside. "By His wounds we are healed" — that is the entire doctrine of atonement in six words.'},
          'jeremiah 29':  {ov:'The context of verse 11 is everything and everything changes when you know it. This is a letter to exiles in Babylon. They have been torn from their homes, their temple is destroyed, false prophets are telling them they\'ll be home in two years. God tells Jeremiah: write them and say this will last 70 years. Build houses. Plant gardens. Pray for the city. The "plans to prosper you" are 70-year plans for people who thought they were getting 2-year plans.',xr:'Romans 8:28; Isaiah 46:10; Proverbs 19:21; Philippians 1:6; Lamentations 3:22-23',th:'The prosperity promised is not financial. The Hebrew shalom is comprehensive well-being — peace, completeness, wholeness. God\'s plan is not for your temporary comfort but for your eternal flourishing. The exile itself is part of the plan, not a deviation from it.',ap:'Preach this passage honestly. "Plans for welfare and not for evil" does not mean plans that feel good right now. It means plans that lead to genuine shalom — which sometimes require a Babylonian exile first. The people who received this letter waited 70 years for its fulfillment.'},
          'john 3':       {ov:'Nicodemus came at night — John never includes such details without meaning. He was a Pharisee and Sanhedrin member with something to lose. Jesus does not ease him into the Kingdom; He goes straight to the foundation: "You must be born again." The Greek anothen means both "again" and "from above." Nicodemus hears "again"; Jesus means "from above." The new birth is not self-improvement — it is divine intervention from outside us.',xr:'1 Peter 1:23; Titus 3:5; Ezekiel 36:25-27; Romans 8:9; Galatians 2:20',th:'John 3:16 is not the highlight of this chapter — the new birth is. "Whoever believes" translates a present Greek participle: ongoing, continuous believing, not a one-time transaction. Saving faith is a continuous entrusting of oneself to Christ, not a past event that has no present implications.',ap:'Help people see that religion and relationship are not the same thing. Nicodemus had religion — three titles in verse 1 alone. What he lacked was regeneration. Ask your congregation: have you been born again, or have you only been religious?'},
          'john 14':      {ov:'"Let not your hearts be troubled" — these words were spoken hours before Gethsemane and the cross, yet every sentence breathes peace. This is the Savior speaking from the calm center of a storm He is about to enter willingly. "I AM the way, the truth, and the life" — not a way, not a truth among many. The definite article is not accidental. The exclusivity of this claim is not cruelty; it is clarity.',xr:'Hebrews 10:19-22; Acts 4:12; 1 Timothy 2:5; John 16:33; Romans 5:1',th:'The Paraclete sayings (vv.16,26) introduce the Holy Spirit as allos parakletos — another Advocate of the same kind. Allos means another of identical nature. The Spirit is not a lesser substitute for Jesus; He is the same presence in a new mode of indwelling, sent by the Father at the Son\'s request.',ap:'When your congregation faces fear — diagnosis, financial collapse, broken relationship — bring them to John 14. Jesus commanded peace the same way He commanded wind and waves. "Let not your hearts be troubled" is not advice; it is authority. Receive it as a divine command backed by the most powerful promises ever spoken.'},
          'acts 2':       {ov:'Pentecost is the birthday of the church — and what a birth. The Holy Spirit falls on 120 people, and before the day is over 3,000 have been added. This did not happen because of a program, a marketing strategy, or a building. It happened because 120 people had been obediently waiting in one place, praying in one accord, for the promise the Father had made. The early church grew because it was filled, not because it was organized.',xr:'Joel 2:28-32; Luke 24:49; Acts 1:8; Romans 8:9; 1 Corinthians 12:13',th:'Peter\'s sermon (vv.14-36) is the first Christian sermon ever preached, and its entire argument is from fulfilled Scripture. The resurrection of Jesus is the interpretive key to the entire Old Testament. Every detail of the Day of Pentecost — the sound, the fire, the languages — has Old Testament roots.',ap:'Challenge your congregation: this was normal Christianity. The church was not supposed to settle into institutional routine; it was supposed to continue in the apostles' teaching, in fellowship, in breaking of bread, in prayer — and the Lord was supposed to keep adding to their number daily.'},
          'romans 3':     {ov:'"For all have sinned and fall short of the glory of God" — this is the most democratic sentence in the Bible. No exceptions, no categories, no hierarchy of sinners. The entire argument of Romans 1-3 has been building to this: every human being, Jew and Gentile alike, stands guilty before a holy God. The good news cannot be received until the bad news is understood. You cannot be saved from a problem you don\'t believe you have.',xr:'Isaiah 53:6; Psalm 14:3; Galatians 3:22; Romans 6:23; 1 John 1:8',th:'Verses 21-26 contain the most compressed statement of the gospel in Scripture. "The righteousness of God" — His own righteousness — is both the standard required and the gift given. "Propitiation" (hilasterion, v.25) is the mercy seat of Leviticus 16 — Jesus is the place where God\'s wrath is satisfied and His mercy is dispensed.',ap:'Preach these verses without softening them. The diagnosis must be clear before the cure is received. People cannot be grateful for a salvation they don\'t understand they needed. Let the weight of "all have sinned" land before you proclaim "justified freely by His grace."'},
          'romans 8':     {ov:'The greatest chapter in the greatest epistle. It opens with no condemnation and closes with no separation. Everything in between is the Spirit-filled life in its fullest description. Verse 28 — "all things work together for good" — is the most abused verse in the NT. Paul is not promising that everything is good. He is promising that God is working in everything toward the good He has defined in verse 29: conformity to Christ.',xr:'Galatians 5:16-25; Philippians 4:11-13; 2 Corinthians 4:17; James 1:2-4; Jeremiah 29:11',th:'The golden chain of salvation (vv.29-30) uses five aorist verbs — foreknew, predestined, called, justified, glorified — treating glorification as already accomplished from the divine perspective. God speaks of what is future from our standpoint with the certainty of what is past from His.',ap:'Tell your suffering congregation that "all things" includes the diagnosis, the betrayal, the financial crisis, the prodigal child. The goal is not your comfort; it is your conformity to Christ. That changes everything about how you preach this passage.'},
          'romans 12':    {ov:'"Therefore" (v.1) points back to eleven chapters of the gospel. Paul never gives a command without first supplying the resources to obey it. The living sacrifice is not religious duty — it is the logical, worshipful response to the mercies of God described in chapters 1-11. The renewed mind (v.2) is the engine that drives all transformation. You cannot live Romans 12 without understanding Romans 1-11.',xr:'Ephesians 4:22-24; Colossians 3:1-2; 1 Peter 2:5; Philippians 4:8; Hebrews 12:1-2',th:'The Greek word for "transformed" is metamorphoo — the same word used for the Transfiguration of Jesus. Genuine renewal is not a cosmetic change but a transformation of substance from the inside out, driven by a completely renovated way of thinking.',ap:'Identity always precedes imperative. You cannot "behave" your way into Christian maturity — you have to "believe" your way into it. Present your congregation with who they are in Christ before you tell them how to live. Transformation always follows revelation, never precedes it.'},
          '1 corinthians 13': {ov:'This is not a wedding poem — it is a corrective placed by Paul between chapters 12 and 14 as a direct rebuke to Corinthian spiritual pride. Gifts were being used to show off rather than to serve. Tongues without love is noise. Knowledge without love inflates. Love is the only thing that outlasts every spiritual gift. Notice: thirteen negative qualities are stripped away (vv.4-7) before the positive portrait of love even begins.',xr:'1 John 4:7-8; Matthew 22:37-39; John 13:35; Galatians 5:22; Colossians 3:14',th:'The verb agapao throughout denotes consistent, chosen behavior in human relationships — not sentimental emotion. The eschatological argument (vv.8-13) is decisive: gifts are provisional tools for the present age; love is eternal because God is love (1 John 4:8), and eternity is union with the God who is love.',ap:'Preach 1 Corinthians 13 as the standard against which every gift, every ministry, and every church program is measured. Ask: could people describe their experience of your church using the thirteen verbs of love in verses 4-7? Patient, kind, not envious, not boastful, not rude, not self-seeking...'},
          'ephesians 2':  {ov:'"Dead in trespasses and sins" — dead, not sick. Not wounded, not struggling, not spiritually weak. Dead. Dead people do not choose life; they need to be raised. This is why grace is not assistance — it is resurrection. "But God" (v.4) are the two most glorious words in the Bible. Everything before them is the diagnosis; everything after them is the cure given entirely at divine initiative.',xr:'Colossians 2:13; Romans 5:6-8; Titus 3:5; John 5:24; 1 Peter 1:3',th:'"By grace you have been saved through faith" uses the perfect passive participle sesosmenoi — you are in a state of having been saved. Salvation is completed action with ongoing effect. This grammatical form simultaneously rules out earning salvation and losing it.',ap:'Preach the "before and after" of Ephesians 2. Verses 1-3: dead, dominated, disobedient, destined for wrath. Verses 4-10: made alive, raised up, seated in heavenly places with Christ. Let your congregation see clearly who they were and who they now are. Identity determines behavior.'},
          'ephesians 6':  {ov:'The armor of God makes no sense without the three chapters of identity that precede it. You are seated in heavenly places (2:6) before you are called to stand in spiritual warfare (6:11). This is God\'s own armor — Isaiah 59:17 describes Yahweh putting it on. You are not manufacturing spiritual protection; you are putting on God Himself. And the posture commanded — "stand firm" — appears four times. You win by refusing to move.',xr:'Isaiah 59:17; 1 Peter 5:8-9; James 4:7; 2 Corinthians 10:4; Revelation 12:11',th:'"Principalities and powers" (archai, exousiai) denotes organized spiritual opposition at supra-personal levels — evil embedded not just in individual demons but in systems, structures, and cultural patterns. Spiritual warfare is corporate, not just personal; the "you" throughout this passage is plural.',ap:'Each piece of armor answers a specific attack: Belt of truth (fight lies with Scripture), Breastplate of righteousness (your standing before God guards your heart from accusation), Feet shod with the gospel (you advance by proclaiming, not retreating), Shield of faith (spoken faith extinguishes specific arrows), Helmet of salvation (guard your thought life), Sword (the spoken Word is your only offensive weapon).'},
          'philippians 4': {ov:'"Rejoice in the Lord always" — Paul wrote this from prison. This is not positive thinking; this is defiant praise from a man in chains. The peace that "passes all understanding" is not the absence of trouble — it is a garrison of God standing guard over your heart while trouble rages all around. The secret of contentment (v.11) is not a personality trait. It is a learned discipline acquired only through seasons of both abundance and desperate need.',xr:'Romans 8:28; Isaiah 26:3; John 14:27; 2 Corinthians 12:9-10; Hebrews 13:5',th:'The Greek word translated "guard" (phroureo, v.7) is military terminology — a garrison of soldiers posted at the city gate. The peace of God does not just comfort; it stations armed sentinels at the entrance of your heart and mind to screen what tries to enter.',ap:'"I can do all things through Christ" (v.13) has been ripped from context by an entire generation of prosperity preaching. Paul\'s context is contentment in poverty and imprisonment — not unlimited human potential. The power of Christ enables the believer to be genuinely content in suffering. That is the miracle being claimed here.'},
          'hebrews 11':   {ov:'The Hall of Faith — but notice what connects every person listed: they all died without receiving the complete promise. Abel, Enoch, Noah, Abraham, Sarah, Moses — "these all died in faith, not having received the things promised, but having seen them and greeted them from afar" (v.13). This is the definition of faith we have domesticated: believing God\'s word even when the evidence contradicts it, even to the end of your natural life.',xr:'Romans 4:18-21; Habakkuk 2:4; 2 Corinthians 5:7; James 2:14-26; Galatians 3:11',th:'Pistis (faith, v.1) — "the substance of things hoped for, the evidence of things not seen" — uses forensic terminology. Faith is the legal title deed to what God has promised. It is the present possession of future realities, not wishful thinking or emotional optimism.',ap:'Preach Hebrews 11 to your discouraged congregation. These were not super-Christians — they were ordinary, flawed, doubting people who chose to take God at His word when circumstances said otherwise. Their message to every generation: you can too. The faith that pleased God then is the same faith that pleases God now.'},
          'revelation 22': {ov:'The final chapter of Scripture completes every theme begun in Genesis: the tree of life returns, the curse is lifted, God dwells with His people, the river of life flows, and the darkness is gone forever. The last invitation in the Bible is the same as the first call of the gospel: "Come." The same Spirit, the same bride, the same Lord — Come. The Bible begins with a garden and ends with a city, but the tree is in both.',xr:'Genesis 2:9; Isaiah 65:17-25; Ezekiel 47:12; Revelation 21:1-4; 1 Corinthians 2:9',th:'The Alpha and Omega (v.13) who spoke creation into existence in Genesis 1 now speaks completion over all things in Revelation 22. History is not random — it is a story told by the One who knows its beginning and its end and has declared Himself to be both.',ap:'Preach Revelation 22 to your weary congregation as the destination that gives meaning to the journey. Every hardship is temporary when you can see the end of the story. Every injustice will be righted. Every tear will be wiped away. The last word in all of history is not chaos — it is "Come."'}
