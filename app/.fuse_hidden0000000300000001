        function filterHymns(cat, el) {
            document.querySelectorAll('.hymn-tab').forEach(function(t){ t.classList.remove('active'); });
            if (el) el.classList.add('active');
            var filtered = cat === 'all' ? HYMNS : HYMNS.filter(function(h){ return h.category === cat; });
            var listEl = document.getElementById('hymnsList');
            if (!listEl) return;
            var catColors = { praise:'#dbeafe', grace:'#dcfce7', faith:'#fef9c3', comfort:'#fce7f3', gospel:'#ffedd5' };
            var catText   = { praise:'#1e40af', grace:'#166534', faith:'#92400e', comfort:'#9d174d', gospel:'#c2410c' };
            listEl.innerHTML = filtered.map(function(h) {
                return '<div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:14px;margin-bottom:8px;cursor:pointer;display:flex;justify-content:space-between;align-items:center" onclick="showHymnDetail(' + h.id + ')">' +
