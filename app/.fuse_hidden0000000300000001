        function buildCommentary(scripture, type) {
            var key = scripture.toLowerCase().trim().replace(/\s*:\s*/g,':').replace(/\s+/g,' ');
            var data = PASSAGE_DB[key];
            if (!data) {
                var bookChap = key.replace(/:\d+([\-\d]*)$/,'').trim();
                data = PASSAGE_DB[bookChap];
            }
            var typeLabels = {expository:'Expository (Verse-by-Verse)',devotional:'Devotional',theological:'Theological Analysis',historical:'Historical-Cultural Background',practical:'Practical Application'};
            var typeIntros = {
                expository:'Walking verse by verse through this text, we find layer upon layer of divine truth. The expositor's task is to stand beneath the text, not above it — letting Scripture speak in its own voice without our assumptions coloring its meaning.',
                devotional:'This passage invites us into personal encounter with the living God. Let it speak not just to your mind but to your heart. Read it slowly. Read it again. Ask the Spirit to make it your own before you make it a sermon.',
                theological:'The doctrinal weight of this passage cannot be overstated. It forms a cornerstone of biblical theology that connects to the full sweep of divine revelation from Genesis to Revelation.',
                historical:'To understand what this passage meant to its original recipients is to understand what it means to us today. Context is not a limitation on application — it is the foundation of accurate application.',
                practical:'Scripture was never meant to remain in the study. Every truth in this passage is designed to change the way we live, love, work, and worship from Monday through Saturday.'
            };
            var header = '<h3 style="color:#1e3a5f;margin-bottom:0.25rem;font-size:1.15rem">' + scripture + '</h3>' +
                '<p style="color:#64748b;font-size:0.88rem;margin-bottom:1rem">' + (typeLabels[type]||'Expository') + ' Commentary &mdash; Bishop Richard G. Clark</p>' +
                '<hr style="margin:1rem 0;border:none;border-top:1px solid #e2e8f0">';
            var body = '';
            if (data) {
                body += '<div style="background:#f0f9ff;border-left:4px solid #1e3a5f;border-radius:0 8px 8px 0;padding:14px 16px;margin-bottom:16px"><p style="font-size:0.75rem;font-weight:700;color:#1e3a5f;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px">Overview</p><p style="line-height:1.88;color:#1e293b;margin:0">' + data.ov + '</p></div>';
                body += '<p style="font-size:0.75rem;font-weight:700;color:#1e3a5f;text-transform:uppercase;letter-spacing:0.06em;margin:16px 0 6px">Textual Analysis</p><p style="line-height:1.88;color:#374151;margin-bottom:16px">' + (typeIntros[type]||typeIntros.expository) + ' The original language of ' + scripture + ' carries theological weight that English translation only partially captures. Read this passage in its immediate context — the verses and chapters surrounding it provide the interpretive framework that guards against reading our own assumptions into the text.</p>';
                body += '<p style="font-size:0.75rem;font-weight:700;color:#1e3a5f;text-transform:uppercase;letter-spacing:0.06em;margin:16px 0 8px">Biblical Cross-References</p><div style="display:flex;flex-direction:column;gap:6px;margin-bottom:16px">' +
                    data.xr.split(';').map(function(r,i){ r=r.trim(); return '<div style="display:flex;gap:8px;align-items:flex-start;padding:8px;background:#fff;border:1px solid #e2e8f0;border-radius:6px"><span style="background:#1e3a5f;color:white;font-size:0.7rem;font-weight:700;padding:2px 7px;border-radius:10px;flex-shrink:0;margin-top:2px">'+(i+1)+'</span><span style="font-size:0.9rem;color:#374151;line-height:1.6">'+r+'</span></div>'; }).join('') + '</div>';
                body += '<p style="font-size:0.75rem;font-weight:700;color:#1e3a5f;text-transform:uppercase;letter-spacing:0.06em;margin:16px 0 6px">Theological Significance</p><p style="line-height:1.88;color:#374151;margin-bottom:16px">' + data.th + '</p>';
                body += '<div style="background:#fef9c3;border-left:4px solid #f59e0b;border-radius:0 8px 8px 0;padding:14px 16px;margin-bottom:16px"><p style="font-size:0.75rem;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px">Practical Application</p><p style="line-height:1.88;color:#78350f;margin:0">' + data.ap + '</p></div>';
            } else {
                var bookName = scripture.replace(/\s*\d.*$/,'').trim();
                body += '<div style="background:#f0f9ff;border-left:4px solid #1e3a5f;border-radius:0 8px 8px 0;padding:14px 16px;margin-bottom:16px"><p style="font-size:0.75rem;font-weight:700;color:#1e3a5f;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px">Overview</p><p style="line-height:1.88;color:#1e293b;margin:0">' + (typeIntros[type]||typeIntros.expository) + ' The passage of ' + scripture + ' rewards careful attention to its context — the verses and chapters surrounding it provide the interpretive framework that guards against reading our own assumptions into the text. Every passage of Scripture is first about God — who He is, what He has done, what He promises — before it is about us.</p></div>';
                body += '<p style="font-size:0.75rem;font-weight:700;color:#1e3a5f;text-transform:uppercase;letter-spacing:0.06em;margin:16px 0 8px">Biblical Cross-References</p><div style="display:flex;flex-direction:column;gap:6px;margin-bottom:16px">' +
                    ['2 Timothy 3:16-17 — All Scripture is profitable for doctrine, reproof, correction, and instruction in righteousness',
                     'Hebrews 4:12 — The word of God is living, active, and sharper than any two-edged sword',
                     'Psalm 119:105 — Your word is a lamp to my feet and a light to my path',
                     'Romans 15:4 — Everything written was written for our instruction and encouragement',
                     'John 5:39 — The Scriptures testify about Christ — every passage finds its deepest meaning in Him'].map(function(r,i){ return '<div style="display:flex;gap:8px;align-items:flex-start;padding:8px;background:#fff;border:1px solid #e2e8f0;border-radius:6px"><span style="background:#1e3a5f;color:white;font-size:0.7rem;font-weight:700;padding:2px 7px;border-radius:10px;flex-shrink:0;margin-top:2px">'+(i+1)+'</span><span style="font-size:0.9rem;color:#374151;line-height:1.6">'+r+'</span></div>'; }).join('') + '</div>';
                body += '<p style="font-size:0.75rem;font-weight:700;color:#1e3a5f;text-transform:uppercase;letter-spacing:0.06em;margin:16px 0 6px">Theological Significance</p><p style="line-height:1.88;color:#374151;margin-bottom:16px">From a pastoral expository perspective, ' + scripture + ' affirms the consistent theological thread running through all of Scripture: (1) the sovereignty and faithfulness of God who never abandons His purposes; (2) the centrality of Christ as the fulfillment of every divine promise; (3) the call of God's people to respond in faith and obedience; and (4) the work of the Holy Spirit applying these truths to the believer's heart and daily life.</p>';
                body += '<div style="background:#fef9c3;border-left:4px solid #f59e0b;border-radius:0 8px 8px 0;padding:14px 16px;margin-bottom:16px"><p style="font-size:0.75rem;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px">Practical Application</p><p style="line-height:1.88;color:#78350f;margin:0">Study ' + scripture + ' in its context — read the chapter before and after. Ask three questions: What does this passage reveal about God? What does it reveal about humanity? What specific response does it call for? Then preach that response concretely and boldly. Move from the ancient text to the modern pew without losing the authority of either.</p></div>';
            }
            body += '<div style="margin-top:1.5rem;padding:1rem;background:linear-gradient(135deg,#1e3a5f,#3b82f6);border-radius:8px;color:white"><p style="margin:0;font-size:0.9rem;font-style:italic">"Visit many good books, but live in the Bible." &mdash; C.H. Spurgeon</p></div>';
            body += '<p style="font-size:0.78rem;color:#94a3b8;margin-top:1rem">&mdash; Bishop's Commentary &middot; Scripture Studio &middot; Richard G. Clark</p>';
            return header + body;
        }

        function getCommentary() {
            var scripture = document.getElementById('commentaryScripture') ? document.getElementById('commentaryScripture').value.trim() : '';
            var type = document.getElementById('commentaryType') ? document.getElementById('commentaryType').value : 'expository';
            if (!scripture) return showToast('Please enter a scripture reference');
            document.getElementById('commentaryLoading').style.display = 'flex';
            document.getElementById('commentaryResult').style.display = 'none';
            setTimeout(function() {
                var html = buildCommentary(scripture, type);
                document.getElementById('commentaryLoading').style.display = 'none';
                document.getElementById('commentaryResult').style.display = 'block';
                document.getElementById('commentaryResultTitle').textContent = scripture + ' Commentary';
                document.getElementById('commentaryResultContent').innerHTML = html;
                addActivity('Generated commentary for ' + scripture);
            }, 1400);
        }

        function copyCommentary() {
            const c = document.getElementById('commentaryResultContent');
            if (!c) return;
            if (navigator.clipboard) navigator.clipboard.writeText(c.innerText).then(() => showToast('Commentary copied!')).catch(() => showToast('Copy failed'));
        }

        function saveCommentaryToNotes() {
            const title = document.getElementById('commentaryResultTitle').textContent;
            const content = document.getElementById('commentaryResultContent').innerText;
            const notes = getNotes();
            notes.push({id:Date.now(), ref:title, text:'', content, date:new Date().toISOString()});
            saveNotes(notes);
            showToast('Saved to Notes!');
        }

