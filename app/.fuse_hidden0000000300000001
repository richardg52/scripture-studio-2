        function loadIllustrations(category, el) {
            var listEl = document.getElementById('illustrationsList');
            if (!listEl) return;
            document.querySelectorAll('.illus-tab').forEach(function(t){ t.classList.remove('active'); });
            if (el) el.classList.add('active');
