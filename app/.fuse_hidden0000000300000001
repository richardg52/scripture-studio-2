        function renderIllustrations(list) {
            var listEl = document.getElementById('illustrationsList');
            if (!listEl) return;
            if (list.length === 0) {
                listEl.innerHTML = '<div style="text-align:center;padding:40px;color:#94a3b8">' +
                    '<div style="font-size:2.5rem;margin-bottom:12px">💡</div>' +
                    '<p style="font-size:1rem;margin-bottom:6px">No illustrations yet</p>' +
                    '<p style="font-size:0.85rem">Click "Add Illustration" to build your library</p></div>';
                return;
            }
            listEl.innerHTML = list.map(function(item){
                var colors = { story:'#dbeafe', quote:'#dcfce7', statistic:'#fef9c3', analogy:'#fce7f3', historical:'#ffedd5' };
                var textColors = { story:'#1e40af', quote:'#166534', statistic:'#92400e', analogy:'#9d174d', historical:'#c2410c' };
                var bg = colors[item.category] || '#f1f5f9';
                var tc = textColors[item.category] || '#374151';
                return '<div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:16px;margin-bottom:12px">' +
                    '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px">' +
                    '<div><h3 style="font-size:1rem;color:#1e293b;margin-bottom:4px">' + item.title + '</h3>' +
                    '<span style="background:' + bg + ';color:' + tc + ';padding:2px 10px;border-radius:12px;font-size:0.75rem;font-weight:600;text-transform:capitalize">' + item.category + '</span></div>' +
                    '<div style="display:flex;gap:6px">' +
                    '<button onclick="copyIllustration(\'' + item.id + '\')" style="background:#f1f5f9;border:none;padding:5px 10px;border-radius:6px;cursor:pointer;font-size:0.8rem">Copy</button>' +
                    '<button onclick="deleteIllustration(\'' + item.id + '\')" style="background:#fee2e2;border:none;padding:5px 10px;border-radius:6px;cursor:pointer;font-size:0.8rem;color:#dc2626">Delete</button></div></div>' +
                    '<p style="font-size:0.95rem;line-height:1.7;color:#374151;margin-bottom:8px">' + item.content + '</p>' +
                    (item.source ? '<p style="font-size:0.8rem;color:#94a3b8;font-style:italic">Source: ' + item.source + '</p>' : '') +
                    (item.tags ? '<div style="margin-top:8px">' + item.tags.split(',').map(function(t){ return '<span style="background:#f1f5f9;color:#64748b;padding:2px 8px;border-radius:12px;font-size:0.75rem;margin-right:4px">' + t.trim() + '</span>'; }).join('') + '</div>' : '') +
                    '</div>';
            }).join('');
        }

        function showNewIllustrationModal() {
            openModal('Add Illustration',
                '<div style="display:flex;flex-direction:column;gap:12px">' +
                '<input id="newIllusTitle" placeholder="Title or Headline" style="padding:10px;border:1px solid #e2e8f0;border-radius:6px;font-size:0.95rem">' +
                '<select id="newIllusCategory" style="padding:10px;border:1px solid #e2e8f0;border-radius:6px;font-size:0.95rem">' +
                '<option value="story">Story / Anecdote</option>' +
                '<option value="quote">Quote</option>' +
                '<option value="statistic">Statistic / Fact</option>' +
                '<option value="analogy">Analogy / Metaphor</option>' +
                '<option value="historical">Historical Illustration</option></select>' +
                '<textarea id="newIllusContent" placeholder="Write your illustration here..." rows="5" style="padding:10px;border:1px solid #e2e8f0;border-radius:6px;font-size:0.95rem;resize:vertical"></textarea>' +
                '<input id="newIllusSource" placeholder="Source (optional)" style="padding:10px;border:1px solid #e2e8f0;border-radius:6px;font-size:0.95rem">' +
                '<input id="newIllusTags" placeholder="Tags (comma-separated, e.g. faith, grace, prayer)" style="padding:10px;border:1px solid #e2e8f0;border-radius:6px;font-size:0.95rem">' +
                '</div>',
                function() {
                    var title = document.getElementById('newIllusTitle') ? document.getElementById('newIllusTitle').value.trim() : '';
                    var content = document.getElementById('newIllusContent') ? document.getElementById('newIllusContent').value.trim() : '';
                    if (!title || !content) { showToast('Title and content are required'); return; }
                    var illus = getIllustrations();
                    illus.push({
                        id: Date.now().toString(),
                        title: title,
                        category: document.getElementById('newIllusCategory') ? document.getElementById('newIllusCategory').value : 'story',
                        content: content,
                        source: document.getElementById('newIllusSource') ? document.getElementById('newIllusSource').value.trim() : '',
                        tags: document.getElementById('newIllusTags') ? document.getElementById('newIllusTags').value.trim() : '',
                        date: new Date().toLocaleDateString()
                    });
                    saveIllustrations(illus);
                    closeModal();
                    loadIllustrations('all');
                    showToast('Illustration saved!');
                }
            );
        }

        function copyIllustration(id) {
            var illus = getIllustrations().find(function(i){ return i.id === id; });
            if (!illus) return;
            if (navigator.clipboard) {
                navigator.clipboard.writeText(illus.title + '\n\n' + illus.content + (illus.source ? '\n\n— ' + illus.source : ''));
            }
            showToast('Illustration copied to clipboard!');
        }

        function deleteIllustration(id) {
            var illus = getIllustrations().filter(function(i){ return i.id !== id; });
            saveIllustrations(illus);
            loadIllustrations('all');
            showToast('Illustration deleted');
        }

        function getIllustrations()  { return safeParse('ss_illustrations', []); }
        function saveIllustrations(d){ localStorage.setItem('ss_illustrations', JSON.stringify(d)); }


        // ============================================================
        // SERMON EVALUATOR
        // ============================================================
        function evaluateSermon() {
            var title = document.getElementById('evalTitle') ? document.getElementById('evalTitle').value.trim() : '';
            var text  = document.getElementById('evalContent') ? document.getElementById('evalContent').value.trim() : '';
            var el    = document.getElementById('evaluationResults');
            if (!el) return;
            if (!text) { showToast('Please paste your sermon text first'); return; }
            el.innerHTML = '<div style="text-align:center;padding:30px;color:#64748b"><div style="width:30px;height:30px;border:3px solid #e2e8f0;border-top-color:#3b82f6;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 10px"></div>Evaluating sermon...</div>';
            setTimeout(function() {
                var words = text.split(/\s+/).length;
                var hasIntro   = text.toLowerCase().includes('today') || text.toLowerCase().includes('this morning') || text.toLowerCase().includes('scripture');
                var hasConc    = text.toLowerCase().includes('amen') || text.toLowerCase().includes('conclusion') || text.toLowerCase().includes('invitation') || text.toLowerCase().includes('respond');
                var hasScripture = /\d+:\d+/.test(text) || text.toLowerCase().includes('says') || text.toLowerCase().includes('written');
                var hasApp     = text.toLowerCase().includes('you') || text.toLowerCase().includes('we') || text.toLowerCase().includes('our');
                var score      = 60 + (hasIntro?10:0) + (hasConc?10:0) + (hasScripture?10:0) + (hasApp?5:0) + (words>300?5:0);
                score = Math.min(score, 98);
                var grade      = score >= 90 ? 'A' : score >= 80 ? 'B' : score >= 70 ? 'C' : 'D';
                var gradeColor = score >= 90 ? '#16a34a' : score >= 80 ? '#2563eb' : score >= 70 ? '#d97706' : '#dc2626';
                el.innerHTML = '<div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:20px;margin-bottom:16px">' +
                    '<div style="display:flex;align-items:center;gap:16px;margin-bottom:16px">' +
                    '<div style="width:64px;height:64px;border-radius:50%;background:' + gradeColor + '22;display:flex;align-items:center;justify-content:center;font-size:1.8rem;font-weight:700;color:' + gradeColor + '">' + grade + '</div>' +
                    '<div><h3 style="font-size:1.1rem;color:#1e293b;margin-bottom:2px">' + (title || 'Untitled Sermon') + '</h3>' +
                    '<p style="color:#64748b;font-size:0.85rem">' + words + ' words &nbsp;&middot;&nbsp; Estimated delivery: ' + Math.round(words/130) + '-' + Math.round(words/100) + ' min</p></div></div>' +
                    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">' +
                    [
                        {label:'Biblical Foundation', score: hasScripture?92:55, note: hasScripture?'Scripture references detected':'Add more direct Scripture references'},
                        {label:'Introduction',        score: hasIntro?88:50,     note: hasIntro?'Opening engages the audience':'Strengthen your opening hook'},
                        {label:'Application',         score: hasApp?90:60,       note: hasApp?'Practical application present':'Add more personal application points'},
                        {label:'Conclusion',          score: hasConc?85:45,      note: hasConc?'Message has clear landing point':'Add a stronger call to action'}
                    ].map(function(c){
                        var col = c.score >= 80 ? '#16a34a' : c.score >= 65 ? '#d97706' : '#dc2626';
                        return '<div style="background:#f8fafc;border-radius:8px;padding:12px">' +
                            '<div style="display:flex;justify-content:space-between;margin-bottom:6px">' +
                            '<span style="font-size:0.85rem;font-weight:600;color:#374151">' + c.label + '</span>' +
                            '<span style="font-size:0.85rem;font-weight:700;color:' + col + '">' + c.score + '/100</span></div>' +
                            '<div style="background:#e2e8f0;border-radius:4px;height:6px;margin-bottom:6px"><div style="background:' + col + ';border-radius:4px;height:6px;width:' + c.score + '%"></div></div>' +
                            '<p style="font-size:0.78rem;color:#64748b">' + c.note + '</p></div>';
                    }).join('') + '</div></div>' +
                    '<div style="background:#f0f9ff;border-radius:8px;padding:14px">' +
                    '<h4 style="color:#1e40af;font-size:0.85rem;margin-bottom:8px">Suggestions for Improvement</h4>' +
                    '<ul style="list-style:none;padding:0;margin:0">' +
                    (!hasScripture ? '<li style="padding:5px 0;font-size:0.9rem;border-bottom:1px solid #dbeafe">&#128198; Add verse references in format Book Chapter:Verse</li>' : '') +
                    (!hasConc      ? '<li style="padding:5px 0;font-size:0.9rem;border-bottom:1px solid #dbeafe">&#127775; Strengthen your closing with a clear invitation or response</li>' : '') +
                    (words < 500   ? '<li style="padding:5px 0;font-size:0.9rem">&#128221; Consider expanding your content — most sermons benefit from 1,000+ words</li>' : '') +
                    '<li style="padding:5px 0;font-size:0.9rem">&#128172; Read aloud before delivering to catch awkward phrasing</li>' +
                    '</ul></div>';
                showToast('Evaluation complete — Grade: ' + grade);
            }, 1200);
        }

