            var ref = AppState.currentBook + ' ' + AppState.currentChapter;
            loadCommentaryBibleText(ref);
            loadCommentary(type, activeTab);
        }


        // ============================================================
        // PASSAGE-AWARE COMMENTARY ENGINE
