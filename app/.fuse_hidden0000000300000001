        function loadPreachingCalendar(filter, el) {
            var el = document.getElementById('preachingCalendarList');
            if (!el) return;
            document.querySelectorAll('.preach-tab').forEach(function(t){ t.classList.remove('active'); });
            if (el) el.classList.add('active');
            var events = getPreachingEvents();
            var today = new Date();
            var filtered = filter === 'upcoming' ? events.filter(function(e){ return new Date(e.date) >= today; }) :
                           filter === 'past'     ? events.filter(function(e){ return new Date(e.date) < today; }) :
                           events.filter(function(e){ return e.series; });
            if (filtered.length === 0) {
                el.innerHTML = '<div style="text-align:center;padding:40px;color:#94a3b8">' +
                    '<div style="font-size:2.5rem;margin-bottom:12px">&#128197;</div>' +
                    '<p style="font-size:1rem;margin-bottom:6px">No preaching dates yet</p>' +
                    '<p style="font-size:0.85rem">Click "Add Preaching Date" to start your calendar</p></div>';
                return;
            }
            el.innerHTML = filtered.sort(function(a,b){ return new Date(a.date)-new Date(b.date); }).map(function(ev){
                var d = new Date(ev.date);
                var isPast = d < today;
                var dateStr = d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'});
                return '<div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:16px;margin-bottom:10px;display:flex;gap:14px;align-items:flex-start">' +
                    '<div style="min-width:50px;text-align:center;background:' + (isPast?'#f1f5f9':'#eff6ff') + ';border-radius:8px;padding:8px 4px">' +
                    '<div style="font-size:1.2rem;font-weight:700;color:' + (isPast?'#64748b':'#2563eb') + '">' + d.getDate() + '</div>' +
                    '<div style="font-size:0.7rem;color:#94a3b8;text-transform:uppercase">' + d.toLocaleString('en-US',{month:'short'}) + '</div></div>' +
                    '<div style="flex:1"><h4 style="font-size:0.95rem;color:#1e293b;margin-bottom:3px">' + ev.title + '</h4>' +
                    '<p style="font-size:0.85rem;color:#64748b;margin-bottom:4px">' + dateStr + (ev.venue?' &middot; '+ev.venue:'') + '</p>' +
                    (ev.scripture?'<span style="background:#dbeafe;color:#1e40af;padding:2px 8px;border-radius:12px;font-size:0.75rem">' + ev.scripture + '</span>':'') +
                    (ev.series?'<span style="background:#f3e8ff;color:#7c3aed;padding:2px 8px;border-radius:12px;font-size:0.75rem;margin-left:4px">' + ev.series + '</span>':'') +
                    '</div>' +
                    '<button onclick="deletePreachingEvent(" + JSON.stringify(ev.id) + ")" style="background:none;border:none;cursor:pointer;color:#94a3b8;font-size:1rem">&#10005;</button></div>';
            }).join('');
        }

