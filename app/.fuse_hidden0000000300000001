            color: #64748b;
            margin-bottom: 0.5rem;
        }

        .journal-entry-content {
            color: #1e293b;
            line-height: 1.7;
        }

        /* Reading Plan */
        .reading-plan-card {
            background: linear-gradient(135deg, #1e3a5f 0%, #3b82f6 100%);
            color: white;
            border-radius: 16px;
            padding: 2rem;
            margin-bottom: 1.5rem;
